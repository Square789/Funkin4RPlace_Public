// glorious copypasta
function startModchartTween(tag, object, propertyMap, duration, options) {
    options.onComplete = (twn) -> {
        PlayState.instance.callOnScripts('onTweenCompleted', [tag]);
        PlayState.instance.modchartTweens.remove(tag);
    };
    PlayState.instance.modchartTweens.set(
        tag,
        FlxTween.tween(
            object,
            propertyMap,
            duration,
            options
        )
    );
}

function getProgressFloat(s, f) {
    return FlxMath.bound((Conductor.songPosition - s) / (f - s), 0.0, 1.0);
}

function onUpdate(dt) {
    floaterTime += dt;
    for (x in floaters) {
        x.sprite.y = (x.floatRange * Math.sin(floaterTime * x.floatSpeed)) + x.baseY;
    }

    var cts = PlayState.instance.chatboxTargetSprite;
    if (cts != null && chatboxFadeInStartTime != chatboxFadeInFinishTime) {
        if (Conductor.songPosition < chatboxFadeInStartTime) {
            cts.shader.fadein_progress_direct = 0.0;
        } else if (Conductor.songPosition > chatboxFadeInFinishTime) {
            cts.shader.fadein_progress_direct = 1.0;
        } else {
            cts.shader.fadein_progress_direct = chatboxFadeInEase(getProgressFloat(chatboxFadeInStartTime, chatboxFadeInFinishTime));
        }
    }

    var triggeredEvents = [];
    while (nextUncheckedEventIdx < eventQueue.length && eventQueue[nextUncheckedEventIdx].time <= Conductor.songPosition) {
        triggeredEvents.push(eventQueue[nextUncheckedEventIdx]);
        nextUncheckedEventIdx += 1;
    }

    for (e in triggeredEvents) {
        if (e.eventName == "meteor_start") {
            meteorStartTime = e.time;
            meteor.visible = true;
            skyEvil.visible = true;
            meteorCloser.visible = true;
            FlxTween.tween(meteor.shader, {hole_radius_direct: 500.0}, 4.2, {ease: FlxEase.quartOut});
        } else if (e.eventName == "meteor_turn_evil") {
            meteorCloserAppearing = true;
            meteorCloser.shader.obscurance_direct = 1.0;
            meteor.angle = 0.0;
            meteorCloser.angle = 0.0;
            meteorCloserApparitionTween = startModchartTween(
                "meteor_grow_evil",
                meteorCloser.shader,
                {obscurance_direct: 0.0},
                e.v1,
                {ease: FlxEase.sineOut}
            );
        } else if (e.eventName == "meteor_impact") {
            PlayState.instance.camGame.shake(0.008, 120.0);
        } else if (e.eventName == "meteor_change_rotation_intensity") {
            meteorRotationIntensity = e.v1;
        } else if (e.eventName == "meteor_change_shake_intensity") {
            meteorShakeIntensity = e.v1;
        } else if (e.eventName == "shake") {
            PlayState.instance.camGame.shake(e.v1, 120.0);
        }
    }

    if (meteorStartTime != -1.0) {
        var meteorProgress = getProgressFloat(meteorStartTime, songLength);
        var easedMeteorProgress = meteorPositionEase(meteorProgress);
        meteor.x = meteorStartValues.x + (meteorFinishValues.x - meteorStartValues.x) * easedMeteorProgress;
        meteor.x += Math.round(FlxG.random.float(-1.0, 1.0) * meteorShakeIntensity);
        meteor.y = meteorStartValues.y + (meteorFinishValues.y - meteorStartValues.y) * easedMeteorProgress;

        // considered to keep it to multiples of 16 to maintain aspect ratio, but jumping was too extreme.
        // this method leads to noticeable jittering of pixels around the borders
        var mscale = (
            meteorStartValues.scale +
            (
                (meteorFinishValues.scale - meteorStartValues.scale) *
                meteorScaleEase(getProgressFloat(meteorScaleStartTime, meteorScaleFinishTime))
            )
        );
        var snappedWidth = Math.round((meteor.frameWidth * mscale) / 2.0) * 2.0;
        meteor.setGraphicSize(snappedWidth);

        meteorCloser.setPosition(meteor.x, meteor.y);
        meteorCloser.scale.set(meteor.scale.x, meteor.scale.y);

        // evil sky progression notes:
        // The evil sky shader is imperfect (as usual) because it already applies to some pixels at 0.0
        // and doesn't erase the whole sprite at 1.0. we ignore that since the bg is largely
        // cutoff in-game.
        // The plan:
        // keep the sky hidden until the meteor turns evil, at which point it will start sticking to the meteor's
        // y position, offset additionally by the overall meteor progress.

        // this roughly leads to the line being on top of the meteor. very inaccurate because of scroll factors i assume.
        var hprogress = FlxMath.bound(((meteor.y + 500) - skyEvil.y) / skyEvil.height, 0.0, 1.0);
        if (!meteorCloser.visible) {
            // hide when not yet visible
            hprogress -= 1.0;
        }
        // move the sky down the harder the meteor moves down,
        // with a heavy rampup towards the end of the song.
        // anything but sky progress control events breh
        hprogress += easedMeteorProgress * 0.325;
        hprogress += Math.pow(easedMeteorProgress, 5.0) * 0.375;
        skyEvil.shader.horizon_progress_direct = hprogress;

        // waiter, waiter! another progress value dependant on random-ass eyeballed math operations
        var cAlpha = Math.floor((Math.pow(hprogress, 3.0) - 0.44) * 255.0);
        var cAlpha = cAlpha > 255 ? 255 : (cAlpha < 0 ? 0 : cAlpha);
        // camHUD.bgColor &= 0x00ffffff;
        // camHUD.bgColor |= cAlpha << 24;
        evilTint.alpha = (cAlpha / 255.0);
    }
}

function onStepHit() {
    if (meteorCloserAppearing) {
        if (meteorCloser.shader.obscurance_direct <= 0.0) {
            meteorCloser.shader.obscurance_direct = 0.0;
            meteorCloserAppearing = false;
        }
    }
    if (meteorRotationIntensity > 0) {
        if (curStep % meteorRotationIntensity == 0) {
            if (meteorCloserAppearing) {
                meteor.flipX = !meteor.flipX;
                meteorCloser.flipX = meteor.flipX;
            } else {
                meteor.angle = (meteor.angle + 90) % 360;
                if (meteor.angle == 0.0) {
                    meteor.flipX = !meteor.flipX;
                }
                meteorCloser.angle = meteor.angle;
                meteorCloser.flipX = meteor.flipX;
            }
        }
    }
}


function onCreatePost() {
    rdBody = PlayState.instance.boyfriendMembers[1];
    rdWings = [PlayState.instance.boyfriendMembers[0], PlayState.instance.boyfriendMembers[2]];
    for (char in rdWings) {
        char.playAnim("idle", true);
        char.animation.stop();
        char.skipDance = true;
    }

    wingsInMissAnimation = false;

    for (f in PlayState.instance.boyfriendMembers) {
        floaters.push({floatRange: 12.0, floatSpeed: 0.9, baseY: f.y, sprite: f});
    }

    evilTint = new FlxSprite(0.0, 0.0);
    makeInflatedPixelGraphic(evilTint, 0xFFFF4500, camHUD.width, camHUD.height);
    evilTint.scrollFactor.set(0.0, 0.0);
    evilTint.cameras = [camHUD];
    evilTint.alpha = 0.0;
    PlayState.instance.add(evilTint);
    // camHUD.bgColor = 0x00FF4500;
}

// Note to self: skipDance is reset to false by Character.playAnim, so be sure to reset it in appropiate places.

// The wings are largely animated by this code and do their best to ignore all dance and bopping instructions.
// The standard animation logic is running on a 10s timer that hopefully stays well enough in sync with RD's animation controller
//   On note hit, the timer is rounded up or down to not create subframe inacurracy
// If the body is idling or in a sing animation, the wings will always copy one of these five states.
// On miss, they will play a sing animation and then on the first frame of the body's miss animation, play a miss animation.
// ↑ This is the only instance where they're taken out of the standard animation logic

var WING_CLONE_ANIMS = ["idle", "singRIGHT", "singLEFT", "singUP", "singDOWN"];

function onUpdatePost(dt) {
    if (rdBody.animation.curAnim != null) {
        var vidx = WING_CLONE_ANIMS.indexOf(rdBody.animation.curAnim.name);
        if (vidx != -1) {
            if (wingsInMissAnimation) {
                // Make wings return to standard behavior if the body is out of a miss animation
                wingTimer = 0.0;
                wingsInMissAnimation = false;
                for (char in rdWings) {
                    char.playAnim("idle", true);
                    char.animation.stop();
                    char.skipDance = true;
                }
            }

            if (!wingsInMissAnimation) {
                wingTimer += dt;
                while (wingTimer > 0.1) {
                    wingTimer -= 0.1;
                    wingAnimationFrame += 1;
                    if (wingAnimationFrame == 6) {
                        wingAnimationFrame = 0;
                    }
                }
                for (char in rdWings) {
                    char.playAnim(
                        rdBody.animation.curAnim.name == "idle" ?
                            rdBody.animation.curAnim.name :
                            ("wing" + rdBody.animation.curAnim.name),
                        true,
                        false,
                        wingAnimationFrame
                    );
                    char.animation.stop();
                    char.skipDance = true;
                }
            }
        } else if (rdBody.animation.curAnim.name == missExpectedAnimation) {
            // Play wing miss animations only once body played first frame in which it's still bright
            if (rdBody.animation.curAnim.curFrame >= 1) {
                missExpectedAnimation = '';
                for (char in rdWings) {
                    _playAnimation(missAnimationToPlay, char);
                }
            }
        }
    }
}

function _playAnimation(animToPlay, character) {
    if (character.animOffsets.exists(animToPlay)) {
        character.playAnim(animToPlay, true);
        character.holdTimer = 0.0;
    }
}

function _setupMissAnimation(expectedBodyAnimName, animToPlay) {
    missAnimationToPlay = animToPlay;
    missExpectedAnimation = expectedBodyAnimName;
    wingsInMissAnimation = true;
}

function noteMiss(noteMemberIdx, noteData, noteType, isSustain, characters) {
    var note = PlayState.instance.notes.members[noteMemberIdx];
    if (!note.noMissAnimation) {
        var animToPlay = 'wing' + PlayState.instance.playerSingAnimations[note.noteData] + 'miss' + note.animSuffix;
        _setupMissAnimation(rdBody.animation.curAnim.name, animToPlay);
        for (char in rdWings) {
            // I'm not gonna care about the alt anim suffix stuff here
            _playAnimation('wing' + PlayState.instance.playerSingAnimations[note.noteData], char);
        }
    }
}

function noteMissPress(direction) {
    // Won't be called if ghost tapping is on.
    // Mostly a copypaste from PlayState.hx

    var animToPlay = 'wing' + PlayState.instance.playerSingAnimations[direction] + 'miss';
    for (char in rdWings) {
        // char.hasMissAnimations condition dropped; we have those, trust
        _setupMissAnimation(rdBody.animation.curAnim.name, animToPlay);
        _playAnimation('wing' + PlayState.instance.playerSingAnimations[direction], char);
    }
}

function goodNoteHit(noteMemberIdx, noteData, noteType, isSustain, characters) {
    var note = PlayState.instance.notes.members[noteMemberIdx];

    missExpectedAnimation = '';
}
