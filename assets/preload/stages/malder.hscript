    meteorStartValues.y = meteor.y;
    meteorStartValues.scale = 0.5;
    meteorFinishValues.x = meteorStartValues.x;
    meteorFinishValues.y = meteorStartValues.y + 400.0;
    meteorFinishValues.scale = 1.0;

    meteorCloser = new BGSprite('malder/Closer_Meteor', meteor.x, meteor.y, meteor.scrollFactor.x, meteor.scrollFactor.y);

    if (PlayState.instance.curSong == "malder-gold") {
        // 1:05.0 snap
        // 1:24.75 afterdrop
        // 1:34.4 rd solo section
        // 1:43.8
        // 1:53.4 final section
        // 2:03.1 impact
        eventQueue.push({time: 9800.0, eventName: "meteor_start", v1: null});
        eventQueue.push({time: 65000.0, eventName: "meteor_turn_evil", v1: 2.5});
        eventQueue.push({time: 84750.0, eventName: "meteor_change_rotation_intensity", v1: 16});
        eventQueue.push({time: 84750.0, eventName: "meteor_change_shake_intensity", v1: 0.5075});
        eventQueue.push({time: 103800.0, eventName: "meteor_change_rotation_intensity", v1: 2});
        eventQueue.push({time: 103800.0, eventName: "meteor_change_shake_intensity", v1: 1.6});
        eventQueue.push({time: 113400.0, eventName: "shake", v1: 0.002});
        eventQueue.push({time: 123100.0, eventName: "meteor_impact", v1: null});
        meteorScaleStartTime = 9700.0;
        meteorScaleFinishTime = 103800.0 + 4000.0;
        meteorScaleFunc = FlxEase.sineOut;
        chatboxFadeInStartTime = 6000.0;
        chatboxFadeInFinishTime = 13000.0;
        // crappy stitch of a sineOut, linear rise and then quartOut
        // deduced by analyzing some video footage and attempting to sync it with the riser in the gold variant
        // this was most certainly no worth it
        // ^ yup, especially cause a linear tween won out in the end anyways
        // chatboxFadeInEase = (x) -> (1.0 - Math.cos((x * Math.PI) / 2.0))*0.5 + x*0.5;
        chatboxFadeInEase = (x) -> chatboxProgressionAlign(FlxEase.linear(x)); // (x) -> (x < 0.5 ? FlxEase.sineOut(x * 2.0) * 0.5 : (0.5 + FlxEase.quartIn((x - 0.5) * 2.0) * 0.5));
    } else {
        // 1:09.8 snap
        // 1:20.7 drop
        // 2:02.0 buildup to low section
        // 2:12.4 rd solo section
        // 2:22.6 buildup out of low section
        // 2:32.8 2nd drop
        // 2:43.1 xqc vocals join
        // 2:53.2 afterdrop/final section
        // 3:03.5 meteor impact
        eventQueue.push({time: 0.0, eventName: "meteor_start", v1: null});
        eventQueue.push({time: 69800.0, eventName: "meteor_turn_evil", v1: 2.5});
        eventQueue.push({time: 80700.0, eventName: "meteor_change_rotation_intensity", v1: 16});
        eventQueue.push({time: 80700.0, eventName: "meteor_change_shake_intensity", v1: 0.5075});
        eventQueue.push({time: 142600.0, eventName: "meteor_change_rotation_intensity", v1: 4});
        eventQueue.push({time: 152800.0, eventName: "meteor_change_rotation_intensity", v1: 2});
        eventQueue.push({time: 163100.0, eventName: "meteor_change_shake_intensity", v1: 1.6});
        eventQueue.push({time: 173200.0, eventName: "shake", v1: 0.002});
