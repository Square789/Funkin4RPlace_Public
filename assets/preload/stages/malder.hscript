        meteorScaleStartTime = 0.0;
        meteorScaleFinishTime = 152800.0 + 4000.0;
        chatboxFadeInStartTime = -1000.0;
        chatboxFadeInFinishTime = 50.0;
        // spent faaar too much time on a tiny effect award
        // chatboxFadeInEase = (x) -> chatboxProgressionAlign((((x-0.5)*1.5874)*((x-0.5)*1.5874)*((x-0.5)*1.5874) + 0.5)*0.75 + x*0.25);
        // chatboxFadeInEase = (x) -> (
        //     x < 0.8 ?
        //         (0.0 + (FlxEase.quadOut((x - 0.0) / 0.8) * 0.8)) :
        //         (0.8 + (FlxEase.sineIn((x - 0.8) / 0.2) * 0.2))
        // );
        // https://graphtoy.com/?f1(x,t)=&v1=false&f2(x,t)=(((x-0.666667)**3*9)+0.666667)*0.5+x*0.5&v2=true&f3(x,t)=clamp((2*x)**1.44,0,1)&v3=false&f4(x,t)=f2(x,t)*(f3(x,t))+x*(1.0-f3(x,t))&v4=false&f5(x,t)=0.206&v5=false&f6(x,t)=f2(x+clamp(f5(x,t)-x*f5(x,t),-3,6),t)&v6=true&grid=1&coords=0.5,0.5,0.6666666666666666
        // This function is x^3, moved into the top 2/3rds of the 0..1 area, mixed with f(x) = x,
        // and x being stretched (stretchFac was eyeballed) so that the function actually crosses close to 0, 0
        chatboxFadeInEase = function (x) {
            var strechFac = 0.206;
            var stretchedX = x + FlxMath.bound(strechFac - x*strechFac, 0.0, strechFac);
            var q = x - 0.666667;
            return chatboxProgressionAlign(((q*q*q*9) + 0.666667) * 0.5 + stretchedX * 0.5);
        };
    }
