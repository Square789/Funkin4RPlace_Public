function chatboxProgressionAlign(v) {
    return v * 0.74 + 0.12;
}

function onCreate() {
    //background
    // sky is 1920 x 1080
    var sky = new BGSprite('malder/Sky', skyOrigin.x + skyFix.x + 50, skyOrigin.y + skyFix.y + 275, skySF.x, 0);
    skyEvil = new BGSprite('malder/SkyEvil', sky.x, sky.y, sky.scrollFactor.x, sky.scrollFactor.y);

    meteor = new BGSprite('malder/Meteor', skyOrigin.x + skyFix.x + 85, skyOrigin.y + skyFix.y - 80, skySF.x + 0.1, skySF.y + 0.1);
